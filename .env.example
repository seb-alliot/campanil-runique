# Copie ce fichier en `.env` puis complète les valeurs.
#   cp .env.example .env
# Ne JAMAIS commiter le vrai `.env` (secrets). Garde `.env` dans .gitignore.

DEBUG=true

IP_SERVER=0.0.0.0
PORT=3000

TZ=Europe/Paris

# ── Base relationnelle (PostgreSQL) ──────────────────────────────────────────
# En docker compose, DB_HOST/MONGO_URI sont surchargés vers les noms de service.
# En local hors Docker, mets DB_HOST=localhost.
DB_ENGINE=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=campanile
DB_USER=postgres
DB_PASSWORD=change-me

DATABASE_URL=postgresql://postgres:change-me@db:5432/campanile

DB_ACQUIRE_TIMEOUT=2000
DB_CONNECT_TIMEOUT=2
DB_IDLE_TIMEOUT=300
DB_MAX_CONNECTIONS=10
DB_MAX_LIFETIME=3600
DB_MIN_CONNECTIONS=2

# ── Base documentaire (MongoDB) — analytics ──────────────────────────────────
MONGO_URI=mongodb://mongo:27017

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Utilise un mot de passe d'application, jamais ton mot de passe principal.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=ton-email@example.com
SMTP_PASS=mot-de-passe-application
SMTP_FROM=ton-email@example.com

# ── Sécurité ─────────────────────────────────────────────────────────────────
# Génère une valeur aléatoire longue et unique.
SECRET_KEY=change-me-genere-une-cle-aleatoire-longue

ENFORCE_HTTPS=false
OG_IMAGE=/media/og-campanile.jpg
ICON_IMAGE=/media/favicon/images.ico