# Copie ce fichier en `.env` dans CE dossier (correcteur/), puis lance le compose.
#   cp .env.example .env
#   docker compose up --build
# Ces valeurs sont des placeholders de dev — aucun secret réel.

DEBUG=true

IP_SERVER=0.0.0.0
PORT=3000

TZ=Europe/Paris

# ── PostgreSQL (métier) ──────────────────────────────────────────────────────
# Les hôtes (db/mongo) sont fixés par le docker-compose ; ne pas mettre localhost ici.
DB_ENGINE=postgres
DB_NAME=campanile
DB_USER=postgres
DB_PASSWORD=change-me

DB_ACQUIRE_TIMEOUT=2000
DB_CONNECT_TIMEOUT=2
DB_IDLE_TIMEOUT=300
DB_MAX_CONNECTIONS=10
DB_MAX_LIFETIME=3600
DB_MIN_CONNECTIONS=2

# ── MongoDB (analytics) ──────────────────────────────────────────────────────
# Surchargé par le compose vers mongodb://mongo:27017 — laissé ici pour info.
MONGO_URI=mongodb://mongo:27017

# ── Email (SMTP) — optionnel pour la correction ──────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_STARTTLS=true
SMTP_USER=ton-email@example.com
SMTP_PASS=mot-de-passe-application
SMTP_FROM=ton-email@example.com

# ── Sécurité ─────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-genere-une-cle-aleatoire-longue

ENFORCE_HTTPS=false
OG_IMAGE=/media/og-campanile.jpg
ICON_IMAGE=/media/favicon/images.ico